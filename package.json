{
  "name": "resolve-dependency-path",
  "version": "5.0.0",
  "description": "Convert a dependency path into a filepath",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "vitest": "vitest",
    "test": "npm run lint && vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-resolve-dependency-path.git"
  },
  "keywords": [
    "dependency",
    "filepath",
    "module"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-resolve-dependency-path/issues"
  },
  "homepage": "https://github.com/dependents/node-resolve-dependency-path",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7",
    "xo": "^2.0.2"
  }
}
